{
  "name": "midnight-homeassistant-911",
  "version": "0.4.0",
  "description": "Midnight Security 911 Integration for Home Assistant",
  "homepage": "https://midnight.security/",
  "author": "Midnight Security, Inc. <team@midnight.security> (https://midnight.security)",
  "repository": {
    "type": "git",
    "url": "https://github.com/midnight-security/midnight-homeassistant-911.git"
  },
  "private": false,
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "semantic-release": "semantic-release"
  },
  "release": {
    "branches": ["master"],
    "tagFormat": "${version}",
    "plugins": [
      "@semantic-release/commit-analyzer",
      "@semantic-release/release-notes-generator",
      [
        "@semantic-release/exec",
        {
          "prepareCmd": "sed -i 's/\"version\": \"[^\"]*\"/\"version\": \"${nextRelease.version}\"/' package.json custom_components/midnight_alerts/manifest.json && cd custom_components/midnight_alerts && zip -r midnight_alerts.zip . -x 'midnight_alerts.zip'"
        }
      ],
      [
        "@semantic-release/git",
        {
          "assets": [
            "package.json",
            "custom_components/midnight_alerts/manifest.json"
          ],
          "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
        }
      ],
      [
        "@semantic-release/github",
        {
          "assets": [
            {
              "path": "custom_components/midnight_alerts/midnight_alerts.zip",
              "label": "midnight_alerts.zip"
            }
          ]
        }
      ],
      [
        "@saithodev/semantic-release-backmerge",
        {
          "backmergeBranches": ["develop"],
          "backmergeStrategy": "merge"
        }
      ]
    ]
  },
  "devDependencies": {
    "@saithodev/semantic-release-backmerge": "^4.0.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "semantic-release": "^24.2.9"
  }
}
